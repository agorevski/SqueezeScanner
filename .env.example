# Network binding. Copy this file to .env and edit for your machine/tailnet.
SQUEEZE_SCANNER_HOST=100.126.90.82
SQUEEZE_SCANNER_PORT=7890

# Enable Uvicorn auto-reload for local development.
SQUEEZE_SCANNER_RELOAD=false

# Raw market data cache. Scores are not cached.
SQUEEZE_SCANNER_CACHE_DB=data/market_data_cache.sqlite3
SQUEEZE_SCANNER_CACHE_TTL_SECONDS=3600

# Local scheduler defaults. Keep enabled for zero-config local mode; disable only
# when an external worker is responsible for polling due schedules.
SQUEEZE_SCANNER_SCHEDULER_ENABLED=true
SQUEEZE_SCANNER_SCHEDULER_POLL_SECONDS=30

# Optional owner tag for newly-created screens, watchlists, schedules, and alerts.
# This is auth-ready metadata only; local mode does not require authentication.
SQUEEZE_SCANNER_DEFAULT_OWNER_ID=

# Provider selection. Yahoo remains the zero-config default; optional premium
# providers are disabled until a vendor-specific adapter and credentials are configured
# through environment variables or a secrets manager.
SQUEEZE_SCANNER_QUOTE_PROVIDER=yahoo
SQUEEZE_SCANNER_BORROW_PROVIDER=disabled
SQUEEZE_SCANNER_SHORT_INTEREST_PROVIDER=disabled
SQUEEZE_SCANNER_CORPORATE_ACTIONS_PROVIDER=disabled
SQUEEZE_SCANNER_FILINGS_PROVIDER=disabled
SQUEEZE_SCANNER_EVENT_PROVIDER=disabled

# Alert delivery is disabled by default. Use "noop" for dry-run or "webhook" for POST delivery.
SQUEEZE_SCANNER_ALERT_DELIVERY_CHANNELS=
SQUEEZE_SCANNER_ALERT_WEBHOOK_URL=
SQUEEZE_SCANNER_ALERT_WEBHOOK_TIMEOUT_SECONDS=5
SQUEEZE_SCANNER_PUBLIC_BASE_URL=
